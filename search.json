---
layout: null
permalink: /search.json
---
[
{% assign indexed_posts = site.posts | sort: 'date' | reverse %}
{% for post in indexed_posts %}
  {% assign category_key = post.categories | first | default: 'seo' %}
  {% assign hub = site.data.content_hubs[category_key] %}
  {
    "title": {{ post.title | jsonify }},
    "description": {{ post.description | default: '' | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "category": {{ category_key | jsonify }},
    "category_label": {{ hub.label | default: category_key | jsonify }},
    "date": "{{ post.date | date: '%Y-%m-%d' }}"
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
