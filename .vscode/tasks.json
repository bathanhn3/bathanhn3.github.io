{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Jekyll: install gems",
      "type": "shell",
      "command": "bundle install",
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Jekyll: serve local",
      "type": "shell",
      "command": "bundle exec jekyll serve --livereload --host 127.0.0.1 --port 4000",
      "options": {
        "env": {
          "RUBYOPT": "-r./ruby4_jekyll_compat"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
